{
  "name": "telegram-codex-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Turn Telegram into a control plane for the Codex installation already running on your server.",
  "type": "module",
  "homepage": "https://github.com/InDreamer/telegram-codex-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InDreamer/telegram-codex-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/InDreamer/telegram-codex-bridge/issues"
  },
  "keywords": [
    "telegram",
    "codex",
    "bridge",
    "vps",
    "automation",
    "cli",
    "agent"
  ],
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "bin": {
    "ctb": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
